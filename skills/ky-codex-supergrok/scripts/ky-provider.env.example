# ~/.codex/ky-provider.env  (chmod 600) — 不要提交到 Git

# DeepSeek 官网 https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...

# OpenRouter（Claude/Gemini 等）https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# 中转站 / 自定义 OpenAI 兼容接口（可跑 Claude 等）
# RELAY_BASE_URL=https://your-relay.example.com/v1
# RELAY_API_KEY=sk-...
# RELAY_MODEL=claude-sonnet-4
# 可选：RELAY_CHAT_PATH=/v1/chat/completions
