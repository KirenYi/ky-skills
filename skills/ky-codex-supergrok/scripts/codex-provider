#!/usr/bin/env bash
# Multi-profile Codex model switcher (OpenAI / SuperGrok / OpenRouter models).
# Usage:
#   codex-provider list
#   codex-provider status
#   codex-provider use <profile> [--no-restart]
#   codex-provider pick              # macOS GUI picker
#   codex-provider grok|openai|...   # aliases for use
#   codex-provider toggle            # openai <-> last non-openai (or grok)
set -euo pipefail

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CONFIG="$CODEX_HOME/config.toml"
STATE="$CODEX_HOME/provider-mode"
LAST_ALT="$CODEX_HOME/provider-mode-alt"
BACKUP_DIR="$CODEX_HOME/provider-switch-backups"
BIN="$CODEX_HOME/bin"
APP_NAME="${CODEX_DESKTOP_APP:-ChatGPT}"
ENV_FILE="$CODEX_HOME/ky-provider.env"

# Locate profiles.json: installed copy or alongside this script
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROFILES_JSON="${KY_CODEX_PROFILES:-}"
if [[ -z "$PROFILES_JSON" ]]; then
  for c in \
    "$SCRIPT_DIR/profiles.json" \
    "$CODEX_HOME/ky-profiles.json" \
    "$HOME/.agents/skills/ky-codex-supergrok/scripts/profiles.json" \
    "$HOME/.grok/skills/ky-codex-supergrok/scripts/profiles.json" \
    "$HOME/.codex/skills/ky-codex-supergrok/scripts/profiles.json"
  do
    if [[ -f "$c" ]]; then PROFILES_JSON="$c"; break; fi
  done
fi
if [[ -z "${PROFILES_JSON:-}" || ! -f "$PROFILES_JSON" ]]; then
  echo "profiles.json not found. Re-run install.sh" >&2
  exit 1
fi

mkdir -p "$BACKUP_DIR" "$BIN"

# Load optional secrets
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

notify() {
  local title="$1" body="$2"
  osascript -e "display notification \"${body//\"/\\\"}\" with title \"${title//\"/\\\"}\"" 2>/dev/null || true
  echo "$title: $body"
}

usage() {
  cat <<USAGE
Usage: codex-provider <command> [args]

Commands:
  list                 List profiles
  status               Current profile + checks
  use <id>             Switch to profile (restarts ChatGPT/Codex)
  pick                 macOS menu to pick a profile
  toggle               Flip openai <-> previous alt (default grok)
  keys                 Show which env keys are set (not values)
  help

Shortcuts: openai | grok | claude | claude-opus | deepseek | deepseek-r1 | gemini

Flags:
  --no-restart         Do not quit/reopen desktop app

Env file (optional): $ENV_FILE
  OPENROUTER_API_KEY=...
Profiles: $PROFILES_JSON
USAGE
}

NO_RESTART=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --no-restart) NO_RESTART=1 ;;
    -h|--help) usage; exit 0 ;;
    *) ARGS+=("$a") ;;
  esac
done
set -- "${ARGS[@]:-}"

cmd_list() {
  python3 - "$PROFILES_JSON" <<'PY'
import json,sys
from pathlib import Path
d=json.loads(Path(sys.argv[1]).read_text())
for pid,p in d["profiles"].items():
    print(f"{pid:14}  {p.get('label','')}")
    if p.get("description"):
        print(f"{'':14}  {p['description']}")
PY
}

cmd_status() {
  local mode
  mode=$(cat "$STATE" 2>/dev/null || echo "(unknown)")
  echo "mode: $mode"
  echo "profiles: $PROFILES_JSON"
  echo "env file: $ENV_FILE ($( [[ -f $ENV_FILE ]] && echo present || echo missing ))"
  if [[ -x "$BIN/supergrok-proxy" ]]; then
    echo -n "supergrok proxy: "; "$BIN/supergrok-proxy" status || true
  fi
  echo "env keys:"
  for k in OPENROUTER_API_KEY DEEPSEEK_API_KEY ANTHROPIC_API_KEY; do
    if [[ -n "${!k:-}" ]]; then echo "  $k=set"; else echo "  $k=missing"; fi
  done
  if grep -q 'codex-provider-switcher:begin' "$CONFIG" 2>/dev/null; then
    echo "--- managed block ---"
    sed -n '/codex-provider-switcher:begin/,/codex-provider-switcher:end/p' "$CONFIG"
  fi
  echo "root model lines:"
  grep -nE '^(model|model_provider|model_catalog_json|model_reasoning_effort|service_tier)[[:space:]]*=' "$CONFIG" 2>/dev/null | head -20 || true
}

backup_config() {
  local ts; ts=$(date +%Y%m%d-%H%M%S)
  [[ -f "$CONFIG" ]] && cp "$CONFIG" "$BACKUP_DIR/config.toml.$ts"
  ls -1t "$BACKUP_DIR"/config.toml.* 2>/dev/null | tail -n +15 | xargs -I{} rm -f {} 2>/dev/null || true
}

ensure_providers() {
  python3 - "$CONFIG" "$PROFILES_JSON" <<'PY'
import json, re, sys
from pathlib import Path
cfg_path = Path(sys.argv[1])
prof = json.loads(Path(sys.argv[2]).read_text())
text = cfg_path.read_text() if cfg_path.exists() else ""
providers = prof.get("providers") or {}
changed = False
for pid, p in providers.items():
    marker = f"[model_providers.{pid}]"
    if marker in text:
        continue
    block = [f"\n# --- ky-codex-supergrok provider: {pid} ---", marker, f'name = "{p["name"]}"', f'base_url = "{p["base_url"]}"', f'wire_api = "{p.get("wire_api","responses")}"']
    if p.get("env_key"):
        block.append(f'env_key = "{p["env_key"]}"')
    if p.get("supports_websockets") is False:
        block.append("supports_websockets = false")
    block.append("request_max_retries = 4")
    block.append("stream_idle_timeout_ms = 600000")
    headers = p.get("http_headers") or {}
    if headers:
        block.append("http_headers = { " + ", ".join(f'"{k}" = "{v}"' for k,v in headers.items()) + " }")
    text = text.rstrip() + "\n" + "\n".join(block) + "\n"
    changed = True
if changed or not cfg_path.exists():
    cfg_path.parent.mkdir(parents=True, exist_ok=True)
    cfg_path.write_text(text if text.endswith("\n") else text+"\n")
    print("providers ensured")
else:
    print("providers already present")
PY
}

apply_profile() {
  local pid="$1"
  python3 - "$CONFIG" "$PROFILES_JSON" "$pid" <<'PY'
import json, re, sys
from pathlib import Path

cfg_path = Path(sys.argv[1])
data = json.loads(Path(sys.argv[2]).read_text())
pid = sys.argv[3]
if pid not in data["profiles"]:
    print(f"unknown profile: {pid}", file=sys.stderr)
    sys.exit(2)
p = data["profiles"][pid]
text = cfg_path.read_text() if cfg_path.exists() else ""

managed_keys = {
    "model", "model_provider", "model_catalog_json",
    "model_reasoning_effort", "service_tier",
}

lines = text.splitlines(keepends=True)
out = []
in_table = False
skip = False
for line in lines:
    stripped = line.strip()
    if stripped == "# --- codex-provider-switcher:begin ---":
        skip = True
        continue
    if skip:
        if stripped == "# --- codex-provider-switcher:end ---":
            skip = False
        continue
    if stripped.startswith("["):
        in_table = True
        out.append(line)
        continue
    if not in_table and stripped and not stripped.startswith("#"):
        m = re.match(r"^([A-Za-z0-9_\.\-]+)\s*=", stripped)
        if m and m.group(1) in managed_keys:
            continue
    out.append(line)

body = "".join(out).lstrip("\n")
label = p.get("label", pid)
lines_b = [
    "# --- codex-provider-switcher:begin ---",
    f"# Active profile: {pid} — {label}",
    f'# Switch: codex-provider use <id> | pick | list',
    f'model = "{p["model"]}"',
]
if p.get("model_provider"):
    lines_b.append(f'model_provider = "{p["model_provider"]}"')
if p.get("model_catalog_json"):
    lines_b.append(f'model_catalog_json = "{p["model_catalog_json"]}"')
if p.get("model_reasoning_effort"):
    lines_b.append(f'model_reasoning_effort = "{p["model_reasoning_effort"]}"')
if p.get("service_tier"):
    lines_b.append(f'service_tier = "{p["service_tier"]}"')
lines_b.append("# --- codex-provider-switcher:end ---")
block = "\n".join(lines_b) + "\n\n"
cfg_path.parent.mkdir(parents=True, exist_ok=True)
cfg_path.write_text(block + body)
print(f"config set to profile={pid} model={p['model']}")
PY
  echo "$pid" > "$STATE"
  if [[ "$pid" != "openai" ]]; then
    echo "$pid" > "$LAST_ALT"
  fi
}

check_requirements() {
  local pid="$1"
  python3 - "$PROFILES_JSON" "$pid" <<'PY'
import json, os, sys
from pathlib import Path
data=json.loads(Path(sys.argv[1]).read_text())
p=data["profiles"][sys.argv[2]]
errs=[]
for e in p.get("requires_env") or []:
    if not os.environ.get(e):
        errs.append(f"missing env {e} (set in shell or ~/.codex/ky-provider.env)")
for f in p.get("requires_files") or []:
    path=Path(f).expanduser()
    if not path.exists():
        errs.append(f"missing file {path}")
if errs:
    print("REQUIREMENTS_FAILED")
    for e in errs:
        print(e)
    sys.exit(3)
print("ok")
PY
}

start_proxy_if_needed() {
  local pid="$1"
  local need
  need=$(python3 -c "import json;from pathlib import Path;p=json.loads(Path('$PROFILES_JSON').read_text())['profiles']['$pid'];print(p.get('start_proxy') or '')")
  if [[ "$need" == "supergrok" ]]; then
    if [[ -x "$BIN/supergrok-proxy" ]]; then
      env -u http_proxy -u https_proxy -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u all_proxy \
        "$BIN/supergrok-proxy" start >/dev/null 2>&1 \
        || env -u http_proxy -u https_proxy -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u all_proxy \
             "$BIN/supergrok-proxy" restart >/dev/null 2>&1 || true
    fi
  fi
}

restart_desktop() {
  if [[ "$NO_RESTART" == "1" ]]; then
    echo "skip restart (--no-restart)"
    return
  fi
  if pgrep -x "ChatGPT" >/dev/null 2>&1; then
    osascript -e "tell application \"$APP_NAME\" to quit" 2>/dev/null || true
    for _ in $(seq 1 16); do
      pgrep -x "ChatGPT" >/dev/null 2>&1 || break
      sleep 0.5
    done
    pkill -x "ChatGPT" 2>/dev/null || true
    sleep 0.5
  fi
  open -a "$APP_NAME" 2>/dev/null || open -a "ChatGPT" 2>/dev/null || true
}

cmd_use() {
  local pid="$1"
  ensure_providers
  if ! check_requirements "$pid"; then
    echo "Cannot switch to '$pid' — fix requirements above." >&2
    if [[ "$pid" == "claude" || "$pid" == "claude-opus" || "$pid" == "deepseek" || "$pid" == "deepseek-r1" || "$pid" == "gemini" ]]; then
      echo "Create $ENV_FILE with:" >&2
      echo "  OPENROUTER_API_KEY=sk-or-v1-..." >&2
      echo "Get a key: https://openrouter.ai/keys" >&2
    fi
    if [[ "$pid" == "grok" ]]; then
      echo "Run: grok login" >&2
    fi
    exit 3
  fi
  backup_config
  start_proxy_if_needed "$pid"
  apply_profile "$pid"
  local label
  label=$(python3 -c "import json;from pathlib import Path;print(json.loads(Path('$PROFILES_JSON').read_text())['profiles']['$pid']['label'])")
  restart_desktop
  notify "Codex → $label" "已切换。请新建对话使用（勿沿用旧会话）。"
}

cmd_pick() {
  if ! command -v osascript >/dev/null; then
    echo "pick requires macOS osascript; use: codex-provider list && codex-provider use <id>" >&2
    exit 1
  fi
  local tmp choice pid
  tmp=$(mktemp /tmp/codex-pick.XXXXXX)
  python3 -c '
import json, sys
from pathlib import Path
data = json.loads(Path(sys.argv[1]).read_text())
out = Path(sys.argv[2])
escaped = []
for pid, p in data["profiles"].items():
    l = (p.get("label") or pid).replace("\\", "\\\\").replace("\"", "\\\"")
    escaped.append("\"" + l + "\"")
items = ", ".join(escaped)
out.write_text(
    "set opts to {" + items + "}\n"
    "set chosen to choose from list opts with prompt \\"选择 Codex 模型 / 通道：\\" default items {item 1 of opts}\n"
    "if chosen is false then\n  return \\"\\"\nelse\n  return item 1 of chosen\nend if\n"
)
' "$PROFILES_JSON" "$tmp.applescript"
  choice=$(osascript "$tmp.applescript" 2>/dev/null || true)
  rm -f "$tmp" "$tmp.applescript"
  if [[ -z "${choice:-}" ]]; then
    echo "cancelled"
    exit 0
  fi
  pid=$(python3 -c '
import json, sys
from pathlib import Path
data = json.loads(Path(sys.argv[1]).read_text())
label = sys.argv[2]
for pid, p in data["profiles"].items():
    if p.get("label") == label:
        print(pid)
        raise SystemExit(0)
raise SystemExit(2)
' "$PROFILES_JSON" "$choice")
  cmd_use "$pid"
}

cmd_toggle() {
  local cur alt
  cur=$(cat "$STATE" 2>/dev/null || echo openai)
  if [[ "$cur" == "openai" ]]; then
    alt=$(cat "$LAST_ALT" 2>/dev/null || echo grok)
    cmd_use "$alt"
  else
    cmd_use openai
  fi
}

cmd_keys() {
  echo "Checking presence only (values not shown):"
  for k in OPENROUTER_API_KEY DEEPSEEK_API_KEY ANTHROPIC_API_KEY XAI_API_KEY; do
    if [[ -n "${!k:-}" ]]; then echo "  $k: set"; else echo "  $k: missing"; fi
  done
  if [[ -f "$ENV_FILE" ]]; then echo "env file: $ENV_FILE"; else echo "env file missing: $ENV_FILE"; fi
}

cmd="${1:-status}"
case "$cmd" in
  list|ls) cmd_list ;;
  status|st) cmd_status ;;
  use|switch)
    shift || true
    [[ -n "${1:-}" ]] || { usage; exit 2; }
    cmd_use "$1"
    ;;
  pick|menu|ui) cmd_pick ;;
  toggle) cmd_toggle ;;
  keys) cmd_keys ;;
  help) usage ;;
  openai|grok|claude|claude-opus|deepseek|deepseek-r1|gemini)
    cmd_use "$cmd"
    ;;
  *)
    # treat unknown as profile id attempt
    if python3 -c "import json;from pathlib import Path;d=json.loads(Path('$PROFILES_JSON').read_text());import sys;sys.exit(0 if '$cmd' in d['profiles'] else 1)"; then
      cmd_use "$cmd"
    else
      usage
      exit 2
    fi
    ;;
esac
