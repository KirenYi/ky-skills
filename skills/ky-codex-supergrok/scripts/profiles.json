  "providers": {
    "xai": {
      "name": "xAI SuperGrok",
      "base_url": "http://127.0.0.1:18765/v1",
      "wire_api": "responses",
      "env_key": null,
      "supports_websockets": false
    },
    "openrouter": {
      "name": "OpenRouter",
      "base_url": "https://openrouter.ai/api/v1",
      "wire_api": "responses",
      "env_key": "OPENROUTER_API_KEY",
      "supports_websockets": false,
      "http_headers": {
        "HTTP-Referer": "https://github.com/KirenYi/ky-skills",
        "X-Title": "ky-codex-supergrok"
      }
    }
  }
