{
  "version": 2,
  "default": "openai",
  "profiles": {
    "openai": {
      "label": "OpenAI / ChatGPT Codex",
      "description": "官方 ChatGPT 登录额度（如 gpt-5.6-sol）",
      "model": "gpt-5.6-sol",
      "model_provider": null,
      "model_reasoning_effort": "high",
      "service_tier": "fast",
      "model_catalog_json": null,
      "requires_env": [],
      "start_proxy": null,
      "desktop_app": true
    },
    "grok": {
      "label": "SuperGrok 4.5",
      "description": "grok login 订阅通道（非 API Key）",
      "model": "grok-4.5",
      "model_provider": "xai",
      "model_reasoning_effort": "high",
      "service_tier": null,
      "model_catalog_json": "~/.codex/model-catalogs/xai-models.json",
      "requires_env": [],
      "requires_files": ["~/.grok/auth.json"],
      "start_proxy": "supergrok",
      "desktop_app": true
    },
    "claude": {
